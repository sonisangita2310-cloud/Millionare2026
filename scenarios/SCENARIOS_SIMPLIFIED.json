  "scenarios": [
    {
      "id": "S_EMA_12_21_CROSS_LONG",
      "name": "EMA 12/21 Bullish Crossover (1h)",
      "category": "A",
      "type": "LONG",
      "edge_type": "trend_continuation",
      "timeframe_primary": "1h",
      "timeframes": ["1h"],
      "entry": {
        "logic": "AND",
        "conditions": [
          {
            "id": "e1",
            "rule": "EMA_12_1h > EMA_21_1h",
            "description": "12-period EMA above 21-period EMA"
          },
          {
            "id": "e2",
            "rule": "RSI_14_1h > 50",
            "description": "RSI above 50 (positive momentum)"
          }
        ]
      },
      "stop_loss": {
        "formula": "entry_price - (ATR_14_1h * 1.5)"
      },
      "take_profit": [
        {
          "id": "tp1",
          "formula": "entry_price + (ATR_14_1h * 2.0)",
          "size_pct": 50
        },
        {
          "id": "tp2",
          "formula": "entry_price + (ATR_14_1h * 4.0)",
          "size_pct": 50
        }
      ],
      "exit_conditions": [
        {
          "rule": "EMA_12_1h < EMA_21_1h",
          "description": "EMA bearish crossover - exit"
        }
      ],
      "asset_pairs": ["BTC/USDT"],
      "risk_parameters": {
        "expected_win_rate": 0.55,
        "expected_rr": 2.5,
        "expected_dd": 0.08,
        "trades_per_month": 8
      }
    },
